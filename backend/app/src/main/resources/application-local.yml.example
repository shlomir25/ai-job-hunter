# Copy this file to application-local.yml and fill in real values.
# application-local.yml is gitignored.

spring:
  mail:
    host: smtp.gmail.com
    port: 587
    username: your.email@gmail.com
    password: your-google-app-password
    properties:
      mail.smtp.auth: true
      mail.smtp.starttls.enable: true

jobhunter:
  imap:
    host: imap.gmail.com
    port: 993
    username: your.email@gmail.com
    password: your-google-app-password
